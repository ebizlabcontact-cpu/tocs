# =============================================================================
# TOCS Environment Template (.env.example)
# =============================================================================
# Copy to an environment-specific file — NEVER commit secrets:
#
#   local:      .env.local  (or .env for local dev — gitignored)
#   test:       CI job env / .env.test (gitignored if local)
#   production: secret manager or .env.production (gitignored)
#
# This file is safe to commit. Replace placeholder values before use.
# See docs/operations/ENVIRONMENT.md for full policy.
# =============================================================================

# --- Runtime -----------------------------------------------------------------

# local | test | production
NODE_ENV=local

# HTTP listen port (default 3000 in src/http/server.ts)
PORT=3000

# trace | debug | info | warn | error (policy; wire in logging layer when added)
LOG_LEVEL=info

# --- Database ----------------------------------------------------------------

# PostgreSQL connection string (required for app + integration tests)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://tocs:CHANGE_ME@localhost:5432/tocs_db

# --- Secrets (production required; reserved for Auth/RBAC — not MVP) ---------

# Min 32 random bytes as base64 or 64+ char hex. Rotate per ENVIRONMENT.md.
JWT_SECRET=CHANGE_ME_jwt_min_32_chars_random_string_here

# Session signing secret (distinct from JWT_SECRET)
SESSION_SECRET=CHANGE_ME_session_min_32_chars_random_string_here

# Application-level encryption key (distinct from JWT/SESSION)
ENCRYPTION_KEY=CHANGE_ME_encryption_min_32_chars_random_string_here

# --- CI / tooling (optional) -------------------------------------------------

# Set to true in GitHub Actions (automatic on GHA runners)
# CI=true
